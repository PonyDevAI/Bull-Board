{
  "name": "bull-board",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:console & pnpm dev:dashboard",
    "dev:console": "pnpm --filter @bullboard/console dev",
    "dev:dashboard": "pnpm --filter @bullboard/dashboard dev",
    "build": "pnpm build:console && pnpm build:dashboard",
    "build:console": "pnpm --filter @bullboard/console build",
    "build:dashboard": "pnpm --filter @bullboard/dashboard build"
  },
  "engines": { "node": ">=18" },
  "packageManager": "pnpm@9.0.0"
}
